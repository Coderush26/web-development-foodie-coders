{
  "name": "coderush",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "next build",
    "start": "NODE_ENV=production tsx server.ts",
    "lint": "eslint .",
    "test": "node --import tsx --test src/server/alerts/geofence.test.ts src/server/alerts/operational.test.ts src/server/auth/access.test.ts src/server/auth/scope.test.ts src/server/diagnostics/runtime.test.ts src/server/directives/service.test.ts src/server/persistence/state.test.ts src/server/playback/events.test.ts src/server/playback/history.test.ts src/server/routing/operational.test.ts",
    "auth:seed": "tsx src/server/auth/seed.ts",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "leaflet": "^1.9.4",
    "leaflet-draw": "^1.0.4",
    "next": "16.2.6",
    "pg": "^8.20.0",
    "prop-types": "^15.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "react-leaflet-draw": "^0.21.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet-draw": "^1.0.13",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.20.3",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json,yml,yaml}": [
      "prettier --write"
    ]
  }
}
